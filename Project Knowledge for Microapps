approve_order:
sqlcreate or replace function approve_order(p_order_id bigint)
returns void language plpgsql security definer set search_path = public as $$
declare v_email text; v_o orders%rowtype; v_bonus numeric := 0;
begin
  v_email := auth.jwt() ->> 'email';
  if lower(v_email) is distinct from lower('ch.sambasiva998@gmail.com') then raise exception 'Not authorized'; end if;
  select * into v_o from orders where id = p_order_id for update;
  if not found then raise exception 'Order not found'; end if;
  if v_o.status <> 'pending' then raise exception 'Already processed'; end if;
  if v_o.total > 2000 then v_bonus := 50; end if;
  update orders set status = 'paid', stage = 'paid' where id = p_order_id;
  update profiles set wallet = wallet + v_bonus where id = v_o.user_id;
  if v_bonus > 0 then insert into wallet_log (user_id, type, amount) values (v_o.user_id, 'Order reward', v_bonus); end if;
end;
$$;
approve_topup:
sqlcreate or replace function approve_topup(p_topup_id bigint)
returns void language plpgsql security definer set search_path = public as $$
declare v_email text; v_t topup_requests%rowtype;
begin
  v_email := auth.jwt() ->> 'email';
  if lower(v_email) is distinct from lower('ch.sambasiva998@gmail.com') then raise exception 'Not authorized'; end if;
  select * into v_t from topup_requests where id = p_topup_id for update;
  if not found then raise exception 'Top-up not found'; end if;
  if v_t.status <> 'pending' then raise exception 'Already processed'; end if;
  update topup_requests set status = 'approved' where id = p_topup_id;
  update profiles set wallet = wallet + v_t.amount where id = v_t.user_id;
  insert into wallet_log (user_id, type, amount) values (v_t.user_id, 'Wallet recharge', v_t.amount);
end;
$$;
